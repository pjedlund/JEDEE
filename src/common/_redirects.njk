{# Bulk path-prefix redirects (from URL-shape changes). Per-post `redirectFrom:` loop below. #}
/listening/* /jams/:splat 301

{%- for page in collections.all -%}
{%- if page.url and page.data.redirectFrom -%}
{%- for oldUrl in page.data.redirectFrom %}
